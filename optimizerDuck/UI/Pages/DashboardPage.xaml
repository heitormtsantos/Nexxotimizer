<Page
    x:Class="optimizerDuck.UI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:optimizerDuck.UI.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Painel Gamer"
    d:DataContext="{d:DesignInstance pages:DashboardPage}"
    d:DesignHeight="720"
    d:DesignWidth="1180"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    Style="{StaticResource PageRootStyle}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:ProgressBarValueToBrushConverter x:Key="ProgressBarValueToBrushConverter" />
        <SolidColorBrush x:Key="DashPanel" Color="#0A0D14" />
        <SolidColorBrush x:Key="DashPanel2" Color="#101724" />
        <SolidColorBrush x:Key="DashStroke" Color="#1F2A3C" />
        <SolidColorBrush x:Key="DashText" Color="#F7FAFF" />
        <SolidColorBrush x:Key="DashMuted" Color="#9CA8BA" />
        <SolidColorBrush x:Key="DashPurple" Color="#A855F7" />
        <SolidColorBrush x:Key="DashCyan" Color="#22D3EE" />
        <SolidColorBrush x:Key="DashGreen" Color="#24F29B" />

        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource DashStroke}" />
            <Setter Property="Background" Value="{StaticResource DashPanel}" />
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="#03050A" />
        <Border Opacity="0.5">
            <Border.Background>
                <RadialGradientBrush Center="0.08,0.12" GradientOrigin="0.08,0.12" RadiusX="0.76" RadiusY="0.86">
                    <GradientStop Offset="0" Color="#251052" />
                    <GradientStop Offset="0.46" Color="#071225" />
                    <GradientStop Offset="1" Color="#03050A" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Grid
            Panel.ZIndex="1000"
            Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#CC03050A" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="56"
                    Height="56"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,14,0,0"
                    Foreground="{StaticResource DashText}"
                    FontTypography="BodyStrong"
                    Text="{ext:Loc Dashboard.SystemInfo.Loading}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Padding="30,24,30,28" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1180">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel>
                        <ui:TextBlock
                            Foreground="{StaticResource DashPurple}"
                            FontTypography="Caption"
                            Text="NEXXSENSI OTIMIZER" />
                        <ui:TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource DashText}"
                            FontSize="34"
                            FontWeight="SemiBold"
                            Text="Painel gamer" />
                        <ui:TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource DashMuted}"
                            Text="Resumo rapido do PC para jogar com estabilidade." />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,10,0"
                            Appearance="Secondary"
                            Command="{Binding ViewModel.RunCommand}"
                            CommandParameter="TaskManager"
                            Content="Gerenciador"
                            Cursor="Hand"
                            Icon="{ui:SymbolIcon Apps24}" />
                        <ui:Button
                            Appearance="Primary"
                            Command="{Binding ViewModel.RefreshCommand}"
                            Content="Atualizar"
                            Cursor="Hand"
                            Foreground="{DynamicResource AccentButtonForeground}"
                            Icon="{ui:SymbolIcon ArrowClockwise24}" />
                    </StackPanel>
                </Grid>

                <Border Margin="0,24,0,0" Style="{StaticResource DashCard}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border
                            Width="82"
                            Height="82"
                            Background="#070A12"
                            BorderBrush="{StaticResource DashPurple}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Image
                                Margin="8"
                                Source="pack://application:,,,/Resources/Images/NexxsensiLogo.png"
                                Stretch="Uniform" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="18,0,18,0" VerticalAlignment="Center">
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="{Binding ViewModel.SystemHealthLabel, StringFormat='Status do PC: {0}'}" />
                            <ui:TextBlock
                                Margin="0,6,0,0"
                                Foreground="{StaticResource DashMuted}"
                                Text="{Binding ViewModel.SystemInfo.Os.Name}"
                                TextTrimming="CharacterEllipsis" />
                            <ProgressBar
                                Height="6"
                                Margin="0,14,0,0"
                                Maximum="100"
                                Value="{Binding ViewModel.SystemHealthScore, Mode=OneWay}"
                                Foreground="{StaticResource DashGreen}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <ui:TextBlock
                                HorizontalAlignment="Right"
                                Foreground="{StaticResource DashText}"
                                FontSize="32"
                                FontWeight="Bold"
                                Text="{Binding ViewModel.SystemHealthScore, StringFormat='{}{0:F0}%'}" />
                            <ui:TextBlock
                                HorizontalAlignment="Right"
                                Foreground="{StaticResource DashMuted}"
                                FontTypography="Caption"
                                Text="saude geral" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Margin="0,18,0,0" Columns="4">
                    <Border Margin="0,0,12,0" Style="{StaticResource DashCard}">
                        <StackPanel>
                            <ui:SymbolIcon Foreground="{StaticResource DashCyan}" Symbol="DeveloperBoard24" />
                            <ui:TextBlock Margin="0,14,0,0" Foreground="{StaticResource DashMuted}" Text="CPU" />
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding ViewModel.CpuClockGHz, StringFormat='{}{0:F1} GHz'}" />
                            <ui:TextBlock
                                Margin="0,6,0,0"
                                Foreground="{StaticResource DashMuted}"
                                FontSize="12"
                                Text="{Binding ViewModel.SystemInfo.Cpu.Name}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,12,0" Style="{StaticResource DashCard}">
                        <StackPanel>
                            <ui:SymbolIcon Foreground="{StaticResource DashPurple}" Symbol="Desktop24" />
                            <ui:TextBlock Margin="0,14,0,0" Foreground="{StaticResource DashMuted}" Text="GPU" />
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding ViewModel.GpuMemoryGB, StringFormat='{}{0:F0} GB VRAM'}" />
                            <ui:TextBlock
                                Margin="0,6,0,0"
                                Foreground="{StaticResource DashMuted}"
                                FontSize="12"
                                Text="{Binding ViewModel.SystemInfo.PrimaryGpu.Name}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,12,0" Style="{StaticResource DashCard}">
                        <StackPanel>
                            <ui:SymbolIcon Foreground="{StaticResource DashGreen}" Symbol="Memory16" />
                            <ui:TextBlock Margin="0,14,0,0" Foreground="{StaticResource DashMuted}" Text="RAM" />
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding ViewModel.RuntimeRam.UsedPercent, StringFormat='{}{0:F0}% em uso'}" />
                            <ProgressBar
                                Height="5"
                                Margin="0,10,0,0"
                                Maximum="100"
                                Value="{Binding ViewModel.RuntimeRam.UsedPercent, Mode=OneWay}"
                                Foreground="{Binding ViewModel.RuntimeRam.UsedPercent, Mode=OneWay, Converter={StaticResource ProgressBarValueToBrushConverter}}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel>
                            <ui:SymbolIcon Foreground="{StaticResource DashCyan}" Symbol="Storage24" />
                            <ui:TextBlock Margin="0,14,0,0" Foreground="{StaticResource DashMuted}" Text="Disco" />
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding ViewModel.PrimaryStorageUsedPercent, StringFormat='{}{0:F0}% ocupado'}" />
                            <ProgressBar
                                Height="5"
                                Margin="0,10,0,0"
                                Maximum="100"
                                Value="{Binding ViewModel.PrimaryStorageUsedPercent, Mode=OneWay}"
                                Foreground="{Binding ViewModel.PrimaryStorageUsedPercent, Mode=OneWay, Converter={StaticResource ProgressBarValueToBrushConverter}}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,18,0,0" ColumnDefinitions="*,12,*">
                    <Border Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <ui:SymbolIcon
                                Width="26"
                                Height="26"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource DashPurple}"
                                Symbol="Rocket24" />
                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <ui:TextBlock Foreground="{StaticResource DashText}" FontWeight="SemiBold" Text="Pronto para jogar" />
                                <ui:TextBlock
                                    Margin="0,4,0,0"
                                    Foreground="{StaticResource DashMuted}"
                                    Text="Acesse Jogos para boost de emulador e limpeza rapida." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <ui:SymbolIcon
                                Width="26"
                                Height="26"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource DashCyan}"
                                Symbol="Settings24" />
                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <ui:TextBlock Foreground="{StaticResource DashText}" FontWeight="SemiBold" Text="Ajustes do Windows" />
                                <ui:TextBlock
                                    Margin="0,4,0,0"
                                    Foreground="{StaticResource DashMuted}"
                                    Text="Abra configuracoes, energia e tarefas pelo menu lateral." />
                            </StackPanel>
                            <ui:Button
                                Grid.Column="2"
                                Appearance="Secondary"
                                Command="{Binding ViewModel.RunCommand}"
                                CommandParameter="Settings"
                                Content="Abrir" />
                        </Grid>
                    </Border>
                </Grid>

                <ui:TextBlock
                    Margin="0,24,0,10"
                    Foreground="{StaticResource DashText}"
                    FontTypography="BodyStrong"
                    Text="Volumes" />
                <ItemsControl ItemsSource="{Binding ViewModel.RuntimeDisk.Volumes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="14"
                                CornerRadius="8"
                                BorderBrush="{StaticResource DashStroke}"
                                BorderThickness="1"
                                Background="#080C13">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <ui:SymbolIcon
                                        Width="22"
                                        Height="22"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource DashCyan}"
                                        Symbol="HardDrive24" />
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <ui:TextBlock Foreground="{StaticResource DashText}">
                                            <Run Text="{Binding DriveLetter}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding VolumeLabel}" />
                                        </ui:TextBlock>
                                        <ProgressBar
                                            Height="5"
                                            Margin="0,8,0,0"
                                            Maximum="100"
                                            Value="{Binding UsedPercent, Mode=OneWay}"
                                            Foreground="{Binding UsedPercent, Mode=OneWay, Converter={StaticResource ProgressBarValueToBrushConverter}}" />
                                    </StackPanel>
                                    <ui:TextBlock
                                        Grid.Column="2"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource DashMuted}"
                                        Text="{Binding UsedPercent, StringFormat='{}{0:F0}%'}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
