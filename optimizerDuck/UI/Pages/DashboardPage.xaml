<Page
    x:Class="optimizerDuck.UI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:optimizerDuck.UI.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Desempenho"
    d:DataContext="{d:DesignInstance pages:DashboardPage}"
    d:DesignHeight="720"
    d:DesignWidth="1180"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    Margin="0"
    Style="{StaticResource PageRootStyle}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:ProgressBarValueToBrushConverter x:Key="ProgressBarValueToBrushConverter" />

        <SolidColorBrush x:Key="DashBackground" Color="#05070B" />
        <SolidColorBrush x:Key="DashCardFill" Color="#10141B" />
        <SolidColorBrush x:Key="DashCardFillAlt" Color="#151A22" />
        <SolidColorBrush x:Key="DashStroke" Color="#202733" />
        <SolidColorBrush x:Key="DashText" Color="#F8FAFC" />
        <SolidColorBrush x:Key="DashMuted" Color="#9AA4B2" />
        <SolidColorBrush x:Key="DashRed" Color="#EF2838" />
        <SolidColorBrush x:Key="DashRedDark" Color="#7A111B" />
        <SolidColorBrush x:Key="DashCyan" Color="#16D5F5" />
        <SolidColorBrush x:Key="DashGreen" Color="#55C85A" />
        <SolidColorBrush x:Key="DashOrange" Color="#F47B20" />

        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource DashStroke}" />
            <Setter Property="Background" Value="{StaticResource DashCardFill}" />
        </Style>

        <Style x:Key="MetricTitle" TargetType="ui:TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DashText}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricSubtle" TargetType="ui:TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DashMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource DashBackground}">
        <Border Opacity="0.34">
            <Border.Background>
                <RadialGradientBrush Center="0.06,0.18" GradientOrigin="0.06,0.18" RadiusX="0.86" RadiusY="0.9">
                    <GradientStop Offset="0" Color="#18275C" />
                    <GradientStop Offset="0.38" Color="#08101C" />
                    <GradientStop Offset="1" Color="#05070B" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Grid
            Panel.ZIndex="20"
            Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#CC05070B" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="56"
                    Height="56"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,14,0,0"
                    Foreground="{StaticResource DashText}"
                    FontTypography="BodyStrong"
                    Text="{ext:Loc Dashboard.SystemInfo.Loading}" />
            </StackPanel>
        </Grid>

        <ScrollViewer
            x:Name="PerformanceScrollViewer"
            Padding="12,12,12,28"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Width="{Binding ViewportWidth, ElementName=PerformanceScrollViewer}">
                <Border
                    Height="166"
                    CornerRadius="8"
                    ClipToBounds="True"
                    BorderBrush="#2A1117"
                    BorderThickness="1"
                    Background="#07080C">
                    <Grid>
                        <Image
                            Panel.ZIndex="5"
                            Source="pack://application:,,,/Resources/Images/Influ.png"
                            Stretch="UniformToFill" />

                        <Rectangle Opacity="0.92">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0" Color="#E905070B" />
                                    <GradientStop Offset="0.38" Color="#A405070B" />
                                    <GradientStop Offset="0.72" Color="#3305070B" />
                                    <GradientStop Offset="1" Color="#7705070B" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Rectangle Opacity="0.34">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#D9101728" />
                                    <GradientStop Offset="0.42" Color="#3305070B" />
                                    <GradientStop Offset="1" Color="#AAEF2838" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <StackPanel
                            Width="430"
                            Margin="48,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <ui:TextBlock
                                Foreground="{StaticResource DashText}"
                                FontSize="30"
                                FontWeight="Black"
                                Text="DESEMPENHO MÁXIMO." />
                            <ui:TextBlock
                                Margin="0,-2,0,0"
                                Foreground="{StaticResource DashRed}"
                                FontSize="30"
                                FontWeight="Black"
                                Text="ZERO LIMITES." />
                            <ui:TextBlock
                                Margin="0,12,0,0"
                                Foreground="#D7DCE7"
                                FontSize="13"
                                Text="Otimize, limpe e potencialize seu PC para jogar com estabilidade." />
                        </StackPanel>

                        <StackPanel
                            Margin="0,0,28,22"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal">
                            <ui:Button
                                Appearance="Primary"
                                Command="{Binding ViewModel.RefreshCommand}"
                                Content="Atualizar leitura"
                                Foreground="{DynamicResource AccentButtonForeground}"
                                Icon="{ui:SymbolIcon ArrowClockwise24}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Margin="0,8,0,0" Columns="5">
                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="48,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <Border
                                Width="42"
                                Height="42"
                                Background="#2A2E38"
                                CornerRadius="6">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource DashText}"
                                    Symbol="DeveloperBoard24" />
                            </Border>
                            <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricTitle}" Text="CPU" />
                            <ui:TextBlock
                                Grid.Column="1"
                                Grid.Row="1"
                                Style="{StaticResource MetricSubtle}"
                                Text="{Binding ViewModel.SystemInfo.Cpu.Name}" />
                            <ui:TextBlock
                                Grid.ColumnSpan="2"
                                Grid.Row="2"
                                Margin="0,12,0,0"
                                Foreground="{StaticResource DashText}"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{Binding ViewModel.CpuUsagePercent, StringFormat='{}{0:F0}%'}" />
                            <StackPanel Grid.ColumnSpan="2" Grid.Row="3">
                                <ProgressBar
                                    Height="6"
                                    Margin="0,6,0,0"
                                    Maximum="100"
                                    Foreground="{StaticResource DashRed}"
                                    Value="{Binding ViewModel.CpuUsagePercent, Mode=OneWay}" />
                                <ui:TextBlock
                                    Margin="0,8,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="{Binding ViewModel.CpuTemperatureC, StringFormat='Temp. estimada: {0:F0}°C'}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="48,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <Border
                                Width="42"
                                Height="42"
                                Background="#2A2E38"
                                CornerRadius="6">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource DashText}"
                                    Symbol="Desktop24" />
                            </Border>
                            <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricTitle}" Text="GPU" />
                            <ui:TextBlock
                                Grid.Column="1"
                                Grid.Row="1"
                                Style="{StaticResource MetricSubtle}"
                                Text="{Binding ViewModel.SystemInfo.PrimaryGpu.Name}" />
                            <ui:TextBlock
                                Grid.ColumnSpan="2"
                                Grid.Row="2"
                                Margin="0,12,0,0"
                                Foreground="{StaticResource DashText}"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{Binding ViewModel.GpuUsagePercent, StringFormat='{}{0:F0}%'}" />
                            <StackPanel Grid.ColumnSpan="2" Grid.Row="3">
                                <ProgressBar
                                    Height="6"
                                    Margin="0,6,0,0"
                                    Maximum="100"
                                    Foreground="{StaticResource DashRed}"
                                    Value="{Binding ViewModel.GpuUsagePercent, Mode=OneWay}" />
                                <ui:TextBlock
                                    Margin="0,8,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="{Binding ViewModel.GpuTemperatureC, StringFormat='Temp. estimada: {0:F0}°C'}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="48,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <Border
                                Width="42"
                                Height="42"
                                Background="#2A2E38"
                                CornerRadius="6">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource DashText}"
                                    Symbol="Memory16" />
                            </Border>
                            <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricTitle}" Text="RAM" />
                            <ui:TextBlock
                                Grid.Column="1"
                                Grid.Row="1"
                                Style="{StaticResource MetricSubtle}"
                                Text="{Binding ViewModel.RamUsageLabel}" />
                            <ui:TextBlock
                                Grid.ColumnSpan="2"
                                Grid.Row="2"
                                Margin="0,12,0,0"
                                Foreground="{StaticResource DashText}"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{Binding ViewModel.RuntimeRam.UsedPercent, StringFormat='{}{0:F0}%'}" />
                            <StackPanel Grid.ColumnSpan="2" Grid.Row="3">
                                <ProgressBar
                                    Height="6"
                                    Margin="0,6,0,0"
                                    Maximum="100"
                                    Foreground="{StaticResource DashRed}"
                                    Value="{Binding ViewModel.RuntimeRam.UsedPercent, Mode=OneWay}" />
                                <ui:TextBlock
                                    Margin="0,8,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="Memória em uso" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="48,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <Border
                                Width="42"
                                Height="42"
                                Background="#2A2E38"
                                CornerRadius="6">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource DashText}"
                                    Symbol="Storage24" />
                            </Border>
                            <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricTitle}" Text="Armazenamento" />
                            <ui:TextBlock
                                Grid.Column="1"
                                Grid.Row="1"
                                Style="{StaticResource MetricSubtle}"
                                Text="{Binding ViewModel.PrimaryStorageLabel}" />
                            <ui:TextBlock
                                Grid.ColumnSpan="2"
                                Grid.Row="2"
                                Margin="0,12,0,0"
                                Foreground="{StaticResource DashText}"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{Binding ViewModel.StorageUsageLabel}" />
                            <StackPanel Grid.ColumnSpan="2" Grid.Row="3">
                                <ProgressBar
                                    Height="6"
                                    Margin="0,6,0,0"
                                    Maximum="100"
                                    Foreground="{StaticResource DashRed}"
                                    Value="{Binding ViewModel.PrimaryStorageUsedPercent, Mode=OneWay}" />
                                <ui:TextBlock
                                    Margin="0,8,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="{Binding ViewModel.PrimaryStorageUsedPercent, StringFormat='{}{0:F0}% ocupado'}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <ui:TextBlock Style="{StaticResource MetricTitle}" Text="FPS" />
                            <ui:TextBlock
                                Grid.Row="1"
                                Style="{StaticResource MetricSubtle}"
                                Text="Média estimada" />
                            <Canvas
                                Grid.Row="2"
                                Height="34"
                                Margin="0,12,0,0">
                                <Polyline
                                    Stroke="{StaticResource DashRed}"
                                    StrokeThickness="2"
                                    Points="0,24 12,18 24,21 36,11 48,19 60,13 72,16 84,9 96,17 108,12 120,15" />
                            </Canvas>
                            <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                                <ui:TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource DashText}"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="{Binding ViewModel.EstimatedFps, StringFormat='{}{0:F0} FPS'}" />
                                <ui:TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource DashGreen}"
                                    FontSize="12"
                                    Text="Excelente" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,8,0,0" ColumnDefinitions="0.92*,8,1.08*">
                    <Border Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,*">
                            <ui:TextBlock
                                Grid.ColumnSpan="2"
                                Style="{StaticResource MetricTitle}"
                                Text="Status do Sistema" />

                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <Ellipse
                                    Width="146"
                                    Height="146"
                                    Stroke="#33151A"
                                    StrokeThickness="14" />
                                <Ellipse
                                    Width="146"
                                    Height="146"
                                    Stroke="{StaticResource DashRed}"
                                    StrokeThickness="14" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ui:TextBlock
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource DashText}"
                                        FontSize="42"
                                        FontWeight="Black"
                                        Text="{Binding ViewModel.SystemHealthScore, StringFormat='{}{0:F0}'}" />
                                    <ui:TextBlock
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource DashRed}"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="{Binding ViewModel.SystemHealthLabelDisplay}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Column="1" Grid.Row="1" Margin="16,18,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid ColumnDefinitions="24,*,Auto">
                                    <ui:SymbolIcon Foreground="{StaticResource DashRed}" Symbol="CheckmarkCircle24" />
                                    <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricSubtle}" Text="Inicialização" />
                                    <ui:TextBlock Grid.Column="2" Foreground="{StaticResource DashRed}" FontSize="12" Text="Verificar" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="24,*,Auto">
                                    <ui:SymbolIcon Foreground="{StaticResource DashRed}" Symbol="CheckmarkCircle24" />
                                    <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricSubtle}" Text="Serviços" />
                                    <ui:TextBlock Grid.Column="2" Foreground="{StaticResource DashMuted}" FontSize="12" Text="Otimizações" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="24,*,Auto">
                                    <ui:SymbolIcon Foreground="{StaticResource DashRed}" Symbol="CheckmarkCircle24" />
                                    <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricSubtle}" Text="Arquivos temporários" />
                                    <ui:TextBlock Grid.Column="2" Foreground="{StaticResource DashRed}" FontSize="12" Text="Limpar" />
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,12,0,0" ColumnDefinitions="24,*,Auto">
                                    <ui:SymbolIcon Foreground="{StaticResource DashRed}" Symbol="CheckmarkCircle24" />
                                    <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricSubtle}" Text="Cache DNS" />
                                    <ui:TextBlock Grid.Column="2" Foreground="{StaticResource DashMuted}" FontSize="12" Text="Limpo" />
                                </Grid>

                                <Grid Grid.Row="4" Margin="0,12,0,0" ColumnDefinitions="24,*,Auto">
                                    <ui:SymbolIcon Foreground="{StaticResource DashRed}" Symbol="CheckmarkCircle24" />
                                    <ui:TextBlock Grid.Column="1" Style="{StaticResource MetricSubtle}" Text="Fragmentação" />
                                    <ui:TextBlock Grid.Column="2" Foreground="{StaticResource DashMuted}" FontSize="12" Text="0%" />
                                </Grid>

                                <ui:Button
                                    Grid.Row="5"
                                    Width="150"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Appearance="Primary"
                                    Command="{Binding ViewModel.RunCommand}"
                                    CommandParameter="TaskManager"
                                    Content="Otimizar Agora"
                                    Foreground="{DynamicResource AccentButtonForeground}"
                                    Icon="{ui:SymbolIcon Rocket24}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="*,126" RowDefinitions="Auto,*">
                            <StackPanel Orientation="Horizontal">
                                <ui:TextBlock Style="{StaticResource MetricTitle}" Text="Monitor de Temperatura" />
                                <StackPanel Margin="28,0,0,0" Orientation="Horizontal">
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="0,5,6,0"
                                        Fill="{StaticResource DashRed}" />
                                    <ui:TextBlock Style="{StaticResource MetricSubtle}" Text="CPU" />
                                    <Rectangle
                                        Width="8"
                                        Height="8"
                                        Margin="18,5,6,0"
                                        Fill="{StaticResource DashOrange}" />
                                    <ui:TextBlock Style="{StaticResource MetricSubtle}" Text="GPU" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,18,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Rectangle Height="1" Fill="#1A2735" />
                                <Rectangle Grid.Row="1" Height="1" Fill="#1A2735" />
                                <Rectangle Grid.Row="2" Height="1" Fill="#1A2735" />
                                <Rectangle Grid.Row="3" Height="1" Fill="#1A2735" />

                                <Canvas Margin="0,4,0,18">
                                    <Polyline
                                        Stroke="{StaticResource DashOrange}"
                                        StrokeThickness="2"
                                        Points="0,88 28,72 56,77 84,68 112,74 140,71 168,69 196,64 224,75 252,78 280,73 308,82 336,74 364,76 392,70" />
                                    <Polyline
                                        Stroke="{StaticResource DashRed}"
                                        StrokeThickness="2"
                                        Points="0,108 28,104 56,102 84,99 112,104 140,101 168,100 196,96 224,101 252,103 280,105 308,100 336,101 364,98 392,92" />
                                </Canvas>
                            </Grid>

                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,18,0,0">
                                <ui:TextBlock Style="{StaticResource MetricSubtle}" Text="CPU" />
                                <ui:TextBlock
                                    Foreground="{StaticResource DashRed}"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Text="{Binding ViewModel.CpuTemperatureC, StringFormat='{}{0:F0}°C'}" />
                                <ui:TextBlock Margin="0,20,0,0" Style="{StaticResource MetricSubtle}" Text="GPU" />
                                <ui:TextBlock
                                    Foreground="{StaticResource DashOrange}"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Text="{Binding ViewModel.GpuTemperatureC, StringFormat='{}{0:F0}°C'}" />
                                <ui:TextBlock Margin="0,22,0,0" Foreground="{StaticResource DashText}" FontSize="12">
                                    <Run Text="Status: " />
                                    <Run Foreground="{StaticResource DashGreen}" Text="Normal" />
                                </ui:TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <UniformGrid Margin="0,8,0,0" Columns="3">
                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <ui:TextBlock Style="{StaticResource MetricTitle}" Text="Inicialização Rápida" />
                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="Gerencie programas que iniciam com o Windows." />
                            </StackPanel>
                            <ui:TextBlock
                                Grid.Column="1"
                                Foreground="{StaticResource DashOrange}"
                                FontSize="12"
                                Text="Impacto médio" />
                        </Grid>
                    </Border>

                    <Border Margin="0,0,8,0" Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <ui:TextBlock Style="{StaticResource MetricTitle}" Text="Drivers" />
                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="Resumo do hardware detectado." />
                            </StackPanel>
                            <ui:SymbolIcon
                                Grid.Column="1"
                                Foreground="{StaticResource DashGreen}"
                                Symbol="CheckmarkCircle24" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <ui:TextBlock Style="{StaticResource MetricTitle}" Text="Rede" />
                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    Style="{StaticResource MetricSubtle}"
                                    Text="Ping e download dependem do seu provedor." />
                            </StackPanel>
                            <ui:SymbolIcon
                                Grid.Column="1"
                                Foreground="{StaticResource DashGreen}"
                                Symbol="CheckmarkCircle24" />
                        </Grid>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
