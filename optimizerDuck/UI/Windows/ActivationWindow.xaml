<Window
    x:Class="optimizerDuck.UI.Windows.ActivationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Ativacao"
    Width="640"
    Height="520"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#05070D"
    Foreground="White">
    <Grid Margin="34">
        <Border
            Padding="28"
            Background="#10141B"
            BorderBrush="#8B3DFF"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <Image
                    Grid.Row="0"
                    Width="92"
                    Height="92"
                    HorizontalAlignment="Center"
                    Source="pack://application:,,,/Resources/Images/NexxsensiLogo.png"
                    Stretch="Uniform" />

                <ui:TextBlock
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    FontSize="26"
                    FontWeight="Bold"
                    Text="Ativar Nexxsensi Otimizer" />

                <ui:TextBlock
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    Foreground="#AEB7C6"
                    Text="Insira sua key de acesso para liberar o otimizador."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <TextBox
                    x:Name="KeyTextBox"
                    Grid.Row="3"
                    Height="42"
                    Margin="0,28,0,0"
                    CharacterCasing="Upper"
                    FontSize="15"
                    VerticalContentAlignment="Center" />

                <ui:TextBlock
                    x:Name="MessageText"
                    Grid.Row="4"
                    MinHeight="42"
                    Margin="0,12,0,0"
                    VerticalAlignment="Top"
                    Foreground="#FF3B6B"
                    TextWrapping="Wrap" />

                <Grid Grid.Row="5" Margin="0,18,0,0" ColumnDefinitions="*,12,*,12,*">
                    <ui:Button
                        Grid.Column="0"
                        Height="42"
                        Appearance="Secondary"
                        Click="CloseButton_Click"
                        Content="Sair" />
                    <ui:Button
                        x:Name="ActivateButton"
                        Grid.Column="2"
                        Height="42"
                        Appearance="Primary"
                        Click="ActivateButton_Click"
                        Content="Ativar"
                        Foreground="{DynamicResource AccentButtonForeground}"
                        IsDefault="True"
                        Icon="{ui:SymbolIcon Key24}" />
                    <ui:Button
                        Grid.Column="4"
                        Height="42"
                        Appearance="Secondary"
                        Click="BuyKeyButton_Click"
                        Content="Comprar key"
                        Icon="{ui:SymbolIcon ShoppingBag24}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
