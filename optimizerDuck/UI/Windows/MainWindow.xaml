<ui:FluentWindow
    x:Class="optimizerDuck.UI.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:optimizerDuck.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:optpages="clr-namespace:optimizerDuck.UI.Pages.Optimize.Categories"
    xmlns:pages="clr-namespace:optimizerDuck.UI.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:optimizerDuck.UI.ViewModels.Windows"
    xmlns:windows="clr-namespace:optimizerDuck.UI.Windows"
    Title="Nexxsensi Otimizer"
    Width="1350"
    Height="800"
    MinWidth="900"
    MinHeight="500"
    d:DataContext="{d:DesignInstance viewmodels:MainWindowViewModel}"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    ExtendsContentIntoTitleBar="True"
    SnapsToDevicePixels="True"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <ui:NavigationView
            x:Name="RootNavigation"
            Margin="0"
            Padding="0"
            FrameMargin="0"
            IsFooterSeparatorVisible="False"
            IsPaneToggleVisible="True"
            IsTopSeparatorVisible="False"
            PaneDisplayMode="Left"
            Style="{StaticResource AdaptivePaneNavigationViewStyle}"
            TitleBar="{Binding ElementName=TitleBar, Mode=OneWay}">
            <ui:NavigationView.PaneHeader>
                <Grid Height="6" />
            </ui:NavigationView.PaneHeader>
            <ui:NavigationView.MenuItems>
                <controls:FilledNavigationViewItem
                    Content="Início"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Home24}"
                    TargetPageType="{x:Type pages:HomePage}" />

                <controls:FilledNavigationViewItem
                    Content="Desempenho"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon DesktopPulse24}"
                    TargetPageType="{x:Type pages:DashboardPage}" />

                <controls:FilledNavigationViewItem
                    Content="Jogos"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Rocket24}"
                    TargetPageType="{x:Type pages:FreeFirePage}" />

                <controls:FilledNavigationViewItem
                    Content="Energia"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon BatteryCharge24}"
                    TargetPageType="{x:Type pages:OptimizePage}" />

                <ui:NavigationViewItemSeparator Margin="0,2,0,2" />

                <controls:FilledNavigationViewItem
                    Content="Otimizar"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Rocket24}"
                    TargetPageType="{x:Type pages:OptimizePage}" />

                <controls:FilledNavigationViewItem
                    x:Name="CustomizeMenuItem"
                    Content="Personalizar"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Sparkle24}"
                    TargetPageType="{x:Type pages:CustomizePage}" />

                <controls:FilledNavigationViewItem
                    Content="Apps"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Delete24}"
                    TargetPageType="{x:Type pages:BloatwarePage}" />

                <ui:NavigationViewItemSeparator Margin="0,2,0,2" />

                <controls:FilledNavigationViewItem
                    Content="Inicialização"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon WindowArrowUp24}"
                    TargetPageType="{x:Type pages:StartupManagerPage}" />

                <controls:FilledNavigationViewItem
                    Content="Tarefas"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon CalendarLtr24}"
                    TargetPageType="{x:Type pages:ScheduledTasksPage}" />

                <controls:FilledNavigationViewItem
                    Content="Limpeza"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon HardDrive20}"
                    TargetPageType="{x:Type pages:DiskCleanupPage}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItemSeparator Margin="0,2,0,2" />
                <controls:FilledNavigationViewItem
                    Content="Configurações"
                    Cursor="Hand"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.FooterMenuItems>

            <ui:NavigationView.PaneFooter>
                <Border
                    Margin="12,10,12,14"
                    Padding="12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource BrandStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusMedium}">
                    <Grid ColumnDefinitions="52,*">
                        <Border
                            Width="44"
                            Height="44"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="#0B0F16"
                            CornerRadius="22"
                            ClipToBounds="True">
                            <Image
                                Margin="4"
                                Source="pack://application:,,,/Resources/Images/NexxsensiLogo.png"
                                Stretch="Uniform" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                            <ui:TextBlock
                                FontTypography="BodyStrong"
                                Text="Nexxsensi"
                                TextTrimming="CharacterEllipsis" />
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <Border
                                    Padding="6,2"
                                    Background="{DynamicResource BrandPrimaryBrightBrush}"
                                    CornerRadius="6">
                                    <ui:TextBlock
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="PRO" />
                                </Border>
                            </StackPanel>
                            <ui:TextBlock
                                Margin="0,4,0,0"
                                FontTypography="Caption"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Plano ativo"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </ui:NavigationView.PaneFooter>

            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>

        <ui:TitleBar x:Name="TitleBar" />

        <ui:ContentDialogHost x:Name="RootContentDialogPresenter" />
    </Grid>
</ui:FluentWindow>
